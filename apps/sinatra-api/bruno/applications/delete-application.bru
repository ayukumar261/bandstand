meta {
  name: Delete Application
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/applications/{{applicationId}}
  body: none
  auth: none
}

assert {
  res.status: eq 204
}

tests {
  test("response body is empty", function() {
    expect(res.body == null || res.body === "").to.be.true;
  });
}
